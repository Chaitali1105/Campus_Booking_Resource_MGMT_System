{
  "buildCommand": "npm --prefix frontend-react install && npm --prefix frontend-react run build",
  "outputDirectory": "frontend-react/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
